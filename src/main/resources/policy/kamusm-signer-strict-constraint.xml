		<ManifestFilePresent Level="FAIL" />
		<SignedFilesPresent Level="FAIL" />
		<FilenameAdherence Level="WARN" />
		<AllFilesSigned Level="WARN" />
	</ContainerConstraints>
	<PDFAConstraints>

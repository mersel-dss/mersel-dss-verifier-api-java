				<Recognition Level="FAIL" />
				<Signature Level="FAIL" />
				<NotExpired Level="FAIL" />
				<SunsetDate Level="FAIL" />
				<AuthorityInfoAccessPresent Level="WARN" />
				<RevocationDataSkip Level="INFORM">
					<CertificateExtensions>
						<Id>0.4.0.194121.2.1</Id>
						<Id>2.5.29.56</Id>
					</CertificateExtensions>
				</RevocationDataSkip>
				<RevocationInfoAccessPresent Level="WARN" />
				<!-- İMZACI: revocation verisi ZORUNLU (FAIL) -->
				<RevocationDataAvailable Level="FAIL" />
				<AcceptableRevocationDataFound Level="FAIL" />
				<CRLNextUpdatePresent Level="WARN" />
				<!--
				    İMZACI revocation FRESHNESS — KamuSM OCSP real-time
				    (saniyeler içinde güncel), CRL 7 günlük periyot. 24
				    saatten eski revocation verisi "stale" sayılır: iptal
				    edilmiş bir sertifika için sessizce kabul anlamına gelir.
				    eIDAS-QES paralel davranışı: FAIL 24h. Operasyon
				    pencereleri (örn. CRL bakım kesintisi) için bu kontrol
				    nadiren ihlal olur; ihlal olduğunda da "manuel inceleme
				    gerekir" demek "iptal kaçırdı" demekten iyidir.
				-->
				<RevocationFreshness Level="FAIL" Unit="HOURS" Value="24" />
				<!--
				    KeyUsage — İMZACI sertifikası dijital imza üretimine yetkili
				    olmalı. KamuSM Mali Mühür / NES sertifikalarında qualified
				    signature için ETSI EN 319 411-1 nonRepudiation (a.k.a.
				    contentCommitment) bit'ini zorunlu kılar; pratikte
				    digitalSignature ile düzenlenmiş varyantlar da mevcut.
				    DSS bu listeyi OR olarak değerlendirir: ikisinden EN AZ
				    BİRİ varsa OK, hiçbiri yoksa FAIL.

				    NEDEN FAIL? Şifreleme amaçlı düzenlenmiş Mali Mühür
				    sertifikaları (KeyUsage = keyEncipherment + keyAgreement,
				    EKU = TLS Web Client Authentication) bazı üreticilerce
				    yanlışlıkla XML imzalamada kullanılıyor. Eski WARN
				    konfigürasyonu bu vakayı yalnızca uyarıya düşürüyor ve
				    DSS'in pipeline'ı imzayı VALID gösterebiliyordu;
				    TÜBİTAK doğrulayıcısı ise QC kuralı gereği FAIL veriyor.
				    FAIL seviyesi iki doğrulayıcıyı paralel hâle getirir.
				-->

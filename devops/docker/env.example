# Verify API Environment Configuration
# Copy this file to .env and customize for your environment

# ===== Server Configuration =====
SERVER_PORT=8086

# ===== Logging Configuration =====
LOG_LEVEL=INFO
# Options: TRACE, DEBUG, INFO, WARN, ERROR
LOG_PATH=/app/logs

# ===== JVM Configuration =====
JAVA_OPTS=-Xmx1g -Xms512m -XX:+UseG1GC
# For production with more memory:
# JAVA_OPTS=-Xmx2g -Xms1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ===== CORS Configuration =====
CORS_ALLOWED_ORIGINS=*
# For production, specify exact origins:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== TSL Configuration =====
TSL_REFRESH_CRON=0 0 2 * * ?
# Daily at 2 AM (format: second minute hour day month weekday)

# ===== Monitoring Configuration =====
# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# IMPORTANT: Change this in production!

# Prometheus
PROMETHEUS_RETENTION=90d
# Options: 15d, 30d, 90d, 180d, 365d

# ===== Optional: Sentry Error Tracking =====
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Optional: Custom Certificate Store =====
# CUSTOM_TRUSTSTORE_PATH=/app/certs/truststore.jks
# CUSTOM_TRUSTSTORE_PASSWORD=changeit

# ===== Optional: Network Configuration =====
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1

# ===== Spring Profiles =====
# SPRING_PROFILES_ACTIVE=production
# Options: development, test, production

# ===== Signature Validation Behavior =====
# All flags below have safe defaults in application.properties; uncomment
# to override at runtime via Docker / Kubernetes environment.

# Online OCSP/CRL fetch. Disable only on air-gapped / CI environments;
# the default policy profile (signer-strict) requires revocation data.
# ONLINE_VALIDATION_ENABLED=true

# Strict mode: any non-OK SubIndication or timestamp imprint failure marks
# the signature invalid. Set to false to mirror DSS DiagnosticData verbatim
# (relaxed report mode).
# VERIFICATION_STRICT_MODE=true

# DSS validation policy profile (built-in). Values:
#   signer-strict (default) - signer cert OCSP/CRL FAIL, intermediate WARN.
#   strict                  - eIDAS-QES parallel; every layer FAIL.
# DSS_POLICY_PROFILE=signer-strict

# Custom DSS validation policy XML. When set, DSS_POLICY_PROFILE is ignored.
# Spring resource pattern: classpath:, file:, http(s):
# Production: typically file:/etc/mersel-dss-verify/policy.xml
# DSS_POLICY_PATH=

# Turkey-specific XAdES SignedProperties Type URI tolerance.
# Affects ONLY signatures that are cryptographically intact but use the
# legacy KamuSM/GIB Type URI variant (".../v1.3.2/XAdES.xsd#SignedProperties"
# instead of "...#SignedProperties"). When such a signature is detected and
# is the ONLY constraint failure, the verifier reports VALID with an explicit
# warning. Set to false to make the verifier behave like a strict eIDAS
# verifier and reject these signatures as DSS does by default.
# Recommended: leave true for KamuSM / GIB ecosystem (default).
# TR_LEGACY_XADES_TOLERANCE=true

# ===================================================================
# INVALID Signature Notifications (Webhook + Slack)
# ===================================================================
# Tum env'ler OPSIYONEL. Hicbiri set degilse: notifier no-op
# (OkHttpClient bile yaratilmaz - gercek zero-overhead).
# Tam rehber: docs/notifications/HOW_TO_USE.md
#
# Master switch. false yaparsan asagidaki tum endpoint'ler set olsa
# bile bildirim gitmez (acil susturma icin).
# INVALID_SIGNATURE_NOTIFICATION_ENABLED=true

# --- Senaryo 1: Generic Webhook (kendi audit/ticket sistemine) ---
# Tam JSON payload (signature result + base64 content + HMAC header).
# INVALID_SIGNATURE_WEBHOOK_URL=https://internal.example.com/alerts/invalid-signature
# HMAC-SHA256 secret. Set ederseniz alici taraf 'X-Signature' header'i
# ile dogrulayabilir (kaynak guvenligi + replay protection).
# INVALID_SIGNATURE_WEBHOOK_SECRET=your-very-long-random-secret-here

# --- Senaryo 2: Slack Incoming Webhook (kirmizi banth alarm) ---
# Slack workspace > Incoming Webhooks > Add Configuration:
#   https://api.slack.com/messaging/webhooks
# INVALID_SIGNATURE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/XXX

# --- Senaryo 3: Slack Bot File Upload (250KB+ fatura icin ONERILEN) ---
# Dosya files.slack.com'a yuklenir, kanalda native indirilebilir dosya.
# Slack ekosisteminin ICINDE kalir, harici link YOK.
# Setup detaylari: docs/notifications/HOW_TO_USE.md (bot token rehberi).
# Gerekli scope: files:write + chat:write.
# INVALID_SIGNATURE_SLACK_BOT_TOKEN=xoxb-...
# INVALID_SIGNATURE_SLACK_CHANNEL=C01234ABCD  # kanal ID (#kanal-adi degil)

# --- Senaryo 4: Slack-only Inline Base64 (<=8KB icin opt-in) ---
# Dosyayi base64 olarak Slack mesajinin icine code block olarak gomer.
# Tipik fatura/PDF 28KB ustudur, BU MODU KULLANMAYIN; bot upload
# (Senaryo 3) gerekli. Sadece kucuk XML/POC senaryolari icin.
# INVALID_SIGNATURE_SLACK_INLINE_BASE64_ENABLED=false
# INVALID_SIGNATURE_SLACK_INLINE_BASE64_MAX_BYTES=8192

# --- Gizlilik (PII / Mali Muhur Kontrolu) ---
# false yaparsaniz base64 content webhook payload'una ve Slack upload'una
# DAHIL EDILMEZ; sadece metadata (rejection code, signer, file name) gider.
# Mali muhur'lu fatura iceren ortamlar icin dusunulmesi gereken trade-off.
# INVALID_SIGNATURE_NOTIFICATION_INCLUDE_CONTENT=true
# Maks payload boyutu (default 10MB). Bu ustunde notifier metadata-only.
# INVALID_SIGNATURE_NOTIFICATION_MAX_CONTENT_SIZE_BYTES=10485760


        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!--
            ===================================================================
            Build Provenance Properties (release immutability + audit trail)
            ===================================================================
            Bu degerler hem JAR MANIFEST.MF'ine hem Spring Boot
            META-INF/build-info.properties (-> /actuator/info) dosyalarina
            gomulur. Lokal build'te literal "local"/"local-build" default'u
            devrede; CI/CD release akisinda -D ile override edilir.

            Override edilen property'ler:
              mersel.build.revision   = git commit SHA (orn. GITHUB_SHA)
              mersel.build.number     = CI run number (orn. GITHUB_RUN_NUMBER)
              mersel.build.timestamp  = ISO-8601 UTC timestamp
              mersel.build.host       = runner OS+arch
              project.build.outputTimestamp = ayni timestamp (jar mtime sabitler)

            ONEMLI: Property adlarini 'mersel.build.*' prefix'i ile tuttuk.
            Sade 'build.timestamp' adli bir property maven-archiver'in manifest
            interpolation katmaninda OZELDIR (her zaman ${maven.build.timestamp}
            built-in'ine fallback eder) - kendi namespace'imiz override edilebilir.
        -->
        <maven.build.timestamp.format>yyyy-MM-dd'T'HH:mm:ss'Z'</maven.build.timestamp.format>
        <mersel.build.revision>local</mersel.build.revision>
        <mersel.build.number>0</mersel.build.number>
        <mersel.build.timestamp>local-build</mersel.build.timestamp>
        <mersel.build.host>local</mersel.build.host>
        <project.build.outputTimestamp>2026-01-01T00:00:00Z</project.build.outputTimestamp>
    </properties>

